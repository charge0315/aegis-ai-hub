<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aegis AI Hub - Next Gen v5.0</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2338bdf8'><path d='M21 16.5C21 16.88 20.79 17.21 20.47 17.38L12.57 21.82C12.41 21.94 12.21 22 12 22C11.79 22 11.59 21.94 11.43 21.82L3.53 17.38C3.21 17.21 3 16.88 3 16.5V7.5C3 7.12 3.21 6.79 3.53 6.62L11.43 2.18C11.59 2.06 11.79 2 12 2C12.21 2 12.41 2.06 12.57 2.18L20.47 6.62C20.79 6.79 21 7.12 21 7.5V16.5ZM12 4.15L5 8.09V15.91L12 19.85L19 15.91V8.09L12 4.15ZM12 7C10.34 7 9 8.34 9 10C9 11.66 10.34 13 12 13C13.66 13 15 11.66 15 10C15 8.34 13.66 7 12 7Z'/></svg>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="css/style.css?v=5.0">
    <link rel="stylesheet" href="css/main.css">
</head>
<body class="antialiased text-lg">
    <!-- ハンバーガーメニューボタン -->
    <button id="menu-toggle" onclick="UI.toggleSidebar()" class="fixed bottom-8 left-8 z-[110] w-16 h-16 bg-sky-500 text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all">
        <i class="fas fa-bars text-2xl"></i>
    </button>

    <div id="debug-console" class="fixed bottom-4 right-4 z-50 w-full max-w-lg bg-black/80 text-xs text-lime-400 p-6 rounded-2xl font-mono hidden overflow-auto h-56 border border-white/10 backdrop-blur-md shadow-2xl"></div>
    
    <div class="flex min-h-screen">
        <!-- サイドバー -->
        <aside id="sidebar-container" class="fixed inset-y-0 left-0 z-[105] w-[85%] md:w-1/2 transform -translate-x-full transition-transform duration-300 ease-in-out p-6 pb-32 flex-shrink-0">
            <div class="sidebar glass rounded-3xl p-8 h-full flex flex-col gap-10 overflow-y-auto border border-white/10 shadow-2xl">
                <button onclick="UI.toggleSidebar()" class="absolute top-8 right-8 text-slate-400 hover:text-white"><i class="fas fa-times text-3xl"></i></button>
                <div class="text-center">
                    <div class="w-20 h-16 bg-sky-500 rounded-2xl mx-auto mb-4 flex items-center justify-center shadow-lg shadow-sky-500/20"><i class="fas fa-microchip text-3xl text-white"></i></div>
                    <h2 class="font-bold text-2xl tracking-tighter text-white">Aegis Engine v5.0</h2>
                </div>
                <div class="px-2">
                    <div class="relative">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                        <input id="search-input" type="text" placeholder="キーワードで絞り込み..." class="input-glass pl-10 text-sm w-full">
                    </div>
                </div>
                <nav id="dynamic-nav" class="space-y-3 px-2">
                    <p class="text-xs text-slate-500 uppercase font-bold tracking-widest mb-4 px-1 text-white">Sections</p>
                </nav>
                <nav class="space-y-3 px-2 pt-4 border-t border-slate-800">
                    <p class="text-xs text-slate-500 uppercase font-bold tracking-widest mb-4 px-1 text-white">System</p>
                    <a href="javascript:void(0)" onclick="app.showSettings()" class="flex items-center gap-4 p-4 rounded-2xl hover:bg-sky-500/10 text-sky-400 transition-all">
                        <i class="fas fa-cog text-2xl shrink-0"></i> <span class="font-bold text-xl">設定</span>
                    </a>
                </nav>
            </div>
        </aside>

        <main class="flex-grow p-4 md:p-8 lg:p-10 overflow-y-auto">
            <header id="main-header" class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
                <div>
                    <h1 class="text-6xl font-black tracking-tighter mb-6 uppercase">Aegis <span class="text-sky-400">AI Hub</span></h1>
                    <p class="text-xl text-slate-400 leading-relaxed">ユーザーのための「自律型知的エージェント」🛡️🤖</p>
                </div>
                <div class="flex flex-wrap items-center justify-end gap-4 shrink-0">
                    <div class="flex bg-black/20 p-1 rounded-2xl border border-white/5 backdrop-blur-md">
                        <button id="view-grid-btn" onclick="app.setViewMode('grid')" class="w-12 h-12 rounded-xl flex items-center justify-center transition-all hover:bg-white/5"><i class="fas fa-th-large text-slate-400"></i></button>
                        <button id="view-list-btn" onclick="app.setViewMode('list')" class="w-12 h-12 rounded-xl flex items-center justify-center transition-all hover:bg-white/5"><i class="fas fa-list text-slate-400"></i></button>
                    </div>
                    <button onclick="fetchDashboard()" class="glass px-6 py-4 rounded-2xl text-sky-400 hover:bg-sky-500/10 transition-all font-bold text-sm min-w-[160px] flex items-center justify-center gap-2 border border-sky-500/20"><i class="fas fa-sync-alt"></i> 最新情報を更新</button>
                    <button id="gemini-btn" onclick="app.fetchRecommendations()" class="px-6 py-4 rounded-2xl bg-gradient-to-br from-fuchsia-600 to-violet-700 text-white font-black text-sm min-w-[160px] hover:scale-105 transition-all flex items-center justify-center gap-2 shadow-lg shadow-fuchsia-500/20"><i class="fas fa-magic"></i> AIのオススメ</button>
                </div>
            </header>

            <div id="recommendations-container" class="hidden space-y-16 mb-24"></div>

            <!-- AI提案モーダル -->
            <div id="evolution-modal" class="fixed inset-0 z-[120] flex items-center justify-center bg-black/80 backdrop-blur-xl hidden p-4">
                <div class="glass w-full max-w-5xl max-h-[90vh] rounded-[2.5rem] overflow-hidden flex flex-col border border-white/10 shadow-2xl">
                    <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/5">
                        <h2 id="modal-title" class="text-3xl font-black text-white uppercase">AI Proposal</h2>
                        <button onclick="UI.hideEvolutionModal()" class="text-slate-400 hover:text-white"><i class="fas fa-times text-2xl"></i></button>
                    </div>
                    <div id="evolution-content" class="flex-grow overflow-y-auto p-8 space-y-8"></div>
                    <div class="p-8 border-t border-white/5 flex justify-end gap-6 bg-slate-900/50">
                        <button onclick="UI.hideEvolutionModal()" class="px-8 py-4 rounded-2xl text-slate-400 font-bold hover:text-white">キャンセル</button>
                        <button id="apply-evolution-btn" onclick="app.applyProposalToDraft()" class="px-10 py-4 rounded-2xl bg-cyan-500 text-white font-black shadow-lg hover:scale-105 transition-all">エディタに取り込む</button>
                    </div>
                </div>
            </div>

            <!-- 統合設定画面 -->
            <div id="settings-container" class="hidden space-y-16 mb-24">
                <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-10 pb-12 border-b border-white/10">
                    <div class="space-y-2">
                        <h2 class="text-4xl font-black text-white uppercase tracking-tighter flex items-center gap-4">
                            <i class="fas fa-sliders-h text-sky-400"></i>
                            System <span class="text-sky-400">Settings</span>
                        </h2>
                        <p class="text-slate-500 font-medium pl-1">システムの興味関心と情報源を詳細にチューニングします</p>
                    </div>
                    
                    <div class="flex flex-wrap items-center gap-6">
                        <!-- AI アクション：ひとまとめにしてツール感を演出 -->
                        <div class="flex p-1.5 bg-white/5 rounded-2xl border border-white/10 backdrop-blur-md">
                            <button onclick="app.showEvolutionProposal()" class="px-6 py-3 rounded-xl font-bold text-sm text-cyan-400 hover:bg-cyan-500/10 transition-all flex items-center gap-2 whitespace-nowrap">
                                <i class="fas fa-dna"></i> システムを進化
                            </button>
                            <div class="w-px h-6 bg-white/10 self-center mx-1"></div>
                            <button onclick="app.showRestructureProposal()" class="px-6 py-3 rounded-xl font-bold text-sm text-indigo-400 hover:bg-indigo-500/10 transition-all flex items-center gap-2 whitespace-nowrap">
                                <i class="fas fa-project-diagram"></i> ナレッジ再構築
                            </button>
                        </div>

                        <!-- 戻る・保存：重要なアクション -->
                        <div class="flex items-center gap-4">
                            <button onclick="app.fetchDashboard()" class="px-6 py-3.5 rounded-2xl bg-white/5 text-slate-400 font-bold hover:bg-rose-500/10 hover:text-rose-400 border border-white/5 transition-all text-sm flex items-center gap-2 whitespace-nowrap">
                                <i class="fas fa-undo"></i> 保存しないで戻る
                            </button>
                            <button onclick="app.saveAllSettings()" class="px-8 py-3.5 rounded-2xl bg-gradient-to-br from-sky-500 to-blue-600 text-white font-black shadow-lg shadow-sky-500/20 hover:shadow-sky-500/40 hover:scale-105 active:scale-95 transition-all flex items-center gap-3 whitespace-nowrap">
                                <i class="fas fa-save text-lg"></i> 保存してシステムを再構築
                            </button>
                        </div>
                    </div>
                </div>

                <!-- タブ切り替え（大きく、美しく） -->
                <div class="flex gap-4 p-2 bg-black/40 rounded-[2.5rem] border border-white/10 backdrop-blur-xl w-full md:w-fit overflow-x-auto shadow-inner">
                    <button onclick="app.switchSettingsTab('feeds')" id="tab-btn-feeds" class="px-10 py-5 rounded-3xl font-black text-xl transition-all text-sky-400 bg-white/5 whitespace-nowrap shadow-lg"><i class="fas fa-rss mr-3"></i> フィード管理</button>
                    <button onclick="app.switchSettingsTab('categories')" id="tab-btn-categories" class="px-10 py-5 rounded-3xl font-black text-xl transition-all text-slate-400 whitespace-nowrap"><i class="fas fa-tags mr-3"></i> カテゴリ管理</button>
                    <button onclick="app.switchSettingsTab('keywords')" id="tab-btn-keywords" class="px-10 py-5 rounded-3xl font-black text-xl transition-all text-slate-400 whitespace-nowrap"><i class="fas fa-search mr-3"></i> ブランド・キーワード</button>
                </div>

                <div id="tab-content-feeds" class="settings-tab-content space-y-10">
                    <div class="flex justify-between items-center bg-white/5 p-10 rounded-[3rem] border border-white/5 shadow-2xl">
                        <div>
                            <h3 class="text-4xl font-black text-white uppercase tracking-tighter">RSS Feed Sources</h3>
                            <p class="text-slate-500 text-sm mt-1">購読中の情報源URLを管理します</p>
                        </div>
                        <button onclick="app.draftAddFeed()" class="px-8 py-4 rounded-2xl bg-sky-500 text-white font-black text-base hover:scale-105 transition-all shadow-xl shadow-sky-500/30 flex items-center gap-3 whitespace-nowrap">
                            <i class="fas fa-plus"></i> フィードを追加
                        </button>
                    </div>
                    <div id="feed-list" class="px-2"></div>
                </div>

                <div id="tab-content-categories" class="settings-tab-content hidden space-y-10">
                    <div class="flex justify-between items-center bg-white/5 p-10 rounded-[3rem] border border-white/5 shadow-2xl">
                        <div>
                            <h3 class="text-4xl font-black text-white uppercase tracking-tighter">Categories</h3>
                            <p class="text-slate-500 text-sm mt-1">情報の分類カテゴリを定義します</p>
                        </div>
                        <button onclick="app.draftAddInterest('category')" class="px-8 py-4 rounded-2xl bg-sky-500 text-white font-black text-base hover:scale-105 transition-all shadow-xl shadow-sky-500/30 flex items-center gap-3 whitespace-nowrap">
                            <i class="fas fa-plus"></i> カテゴリを追加
                        </button>
                    </div>
                    <div id="category-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 px-2"></div>
                </div>

                <div id="tab-content-keywords" class="settings-tab-content hidden space-y-10">
                    <div class="px-4"><h3 class="text-4xl font-black text-white uppercase tracking-tighter">Brands & Keywords</h3><p class="text-slate-500 text-sm mt-1">カテゴリごとに注目する単語を管理します</p></div>
                    <div id="keyword-list-grouped" class="grid grid-cols-1 gap-10 px-2"></div>
                </div>
            </div>

            <div id="sections-container" class="space-y-24"></div>
        </main>
    </div>

    <!-- 独自ダイアログ -->
    <div id="custom-dialog-container" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/70 backdrop-blur-md hidden p-4">
        <div class="glass w-full max-w-lg rounded-[2.5rem] overflow-hidden flex flex-col border border-white/10 shadow-2xl scale-95 opacity-0 transition-all duration-300" id="custom-dialog-box">
            <div class="p-10 pb-6">
                <h3 id="dialog-title" class="text-3xl font-black text-white tracking-tighter uppercase mb-3">Notification</h3>
                <div id="dialog-message" class="text-slate-300 leading-relaxed text-lg"></div>
            </div>
            <div class="p-10 pt-6 flex justify-end gap-4" id="dialog-actions"></div>
        </div>
    </div>

    <script type="module" src="js/app.js"></script>
</body>
</html>
